# =============================================================================
# Archivo de configuración de variables de entorno
# Copia este archivo como .env y completa con tu API Key real
# =============================================================================

# API Key de Gemini (Google) - Obtener GRATIS en AI Studio:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Modelo de Gemini a utilizar (gemini-3.5-flash es el recomendado)
GEMINI_MODEL=gemini-3.5-flash

# Repositorio de GitHub a analizar (formato: URL completa .git)
GITHUB_REPO_URL=https://github.com/psf/requests.git

# Directorio donde se clonará el repositorio
CLONE_DIR=./repos_clonados
